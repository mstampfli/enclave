/target
**/*.rs.bk
# Never commit secrets or local key material.
*.key
*.pem
/keystore/
.env
# Per-user runtime state written by the client and server.
enclave-*.id
enclave-*-friends.json
enclave-accounts.json
enclave-friends.json
# Server's long-term OPAQUE setup (OPRF seed + keypair). Secret; never commit.
enclave-opaque.setup
